<!-- src/views/pages/events.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('events') %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <nav>
      <ul>
        <li><a href="/"><%= t('home') %></a></li>
        <li><a href="/events"><%= t('events') %></a></li>
        <li><a href="/profile"><%= t('profile') %></a></li>
        <li><a href="/chat"><%= t('chat') %></a></li>
        <% if (user && user.role === 'admin') { %>
          <li><a href="/createEvent"><%= t('createEvent') %></a></li>
        <% } %>
        <li><a href="/logout"><%= t('logout') %></a></li>
        <li><a href="/change-language/en">EN</a></li>
        <li><a href="/change-language/ru">RU</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <h1><%= t('events') %></h1>
    <% if (events.length > 0) { %>
      <ul>
        <% events.forEach(event => { %>
          <li>
            <h2><%= event.title %></h2>
            <p><%= event.description %></p>
            <p><%= t('eventDate') %>: <%= new Date(event.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <p><%= t('eventTime') %>: <%= new Date(event.date).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></p>
            <p><%= t('eventLocation') %>: <%= event.location %></p>
            <form action="/events/register" method="POST">
              <input type="hidden" name="eventId" value="<%= event.id %>">
              <button type="submit"><%= t('register') %></button>
            </form>
            <% if (user && user.role === 'admin') { %>
              <button class="delete-button" onclick="deleteEvent(<%= event.id %>)"><%= t('deleteEvent') %></button>
            <% } %>
          </li>
        <% }); %>
      </ul>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>">&laquo; <%= t('previous') %></a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>"><%= t('next') %> &raquo;</a>
        <% } %>
      </div>
    <% } else { %>
      <p><%= t('noEvents') %></p>
    <% } %>
    <script>
      function deleteEvent(eventId) {
        if (confirm('<%= t('confirmDelete') %>')) {
          fetch(`/events/${eventId}`, {
            method: 'DELETE',
          })
          .then(response => response.json())
          .then(data => {
            if (data.message) {
              alert(data.message);
              location.reload();
            } else {
              alert(data.error);
            }
          })
          .catch(error => {
            console.error('Error:', error);
          });
        }
      }
    </script>
  </main>
  <footer>
    <p>&copy; 2025 <%= t('welcome') %></p>
  </footer>
</body>
</html>