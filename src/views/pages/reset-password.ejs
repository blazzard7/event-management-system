<%- include('../partials/header', { title, currentUser }) %>
<section class="form-card">
  <h1>Новый пароль</h1>
  <form method="post" action="/reset-password/<%= token %>">
    <label>Новый пароль<input type="password" name="password" minlength="6" required></label>
    <label>Повторите пароль<input type="password" name="confirmPassword" minlength="6" required oninput="if(this.value !== this.form.password.value) this.setCustomValidity('Пароли не совпадают'); else this.setCustomValidity('')"></label>
    <button type="submit">Сохранить пароль</button>
  </form>
</section>
<%- include('../partials/footer') %>