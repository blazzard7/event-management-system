<!-- src/views/pages/createEvent.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('createEvent') %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <h1><%= t('welcome') %></h1>
    <nav>
      <a href="/"><%= t('home') %></a>
      <a href="/events"><%= t('events') %></a>
      <a href="/profile"><%= t('profile') %></a>
      <a href="/chat"><%= t('chat') %></a>
      <% if (user && user.role === 'admin') { %>
        <a href="/events/create"><%= t('createEvent') %></a>
      <% } %>
      <a href="/logout"><%= t('logout') %></a>
      <ul>
        <li><a href="/change-language/en">EN</a></li>
        <li><a href="/change-language/ru">RU</a></li>
      </ul>
    </nav>
  </header>
  <main>
    <h1><%= t('createEvent') %></h1>
    <form action="/events" method="POST">
      <label for="title"><%= t('eventName') %>:</label>
      <input type="text" id="title" name="title" required>
      <label for="description"><%= t('eventDescription') %>:</label>
      <textarea id="description" name="description" required></textarea>
      <label for="date"><%= t('eventDate') %>:</label>
      <input type="date" id="date" name="date" required>
      <label for="time"><%= t('eventTime') %>:</label>
      <input type="time" id="time" name="time" required>
      <label for="location"><%= t('eventLocation') %>:</label>
      <input type="text" id="location" name="location" required>
      <button type="submit"><%= t('createEvent') %></button>
    </form>
  </main>
</body>
</html> 