<%- include('../partials/header', { title, currentUser }) %>

<section class="section-head">
  <h1>Локации</h1>
  <a class="button-link secondary" href="/admin/users">Пользователи</a>
</section>

<section class="card">
  <h2>Создать локацию</h2>
  <form method="post" action="/admin/locations" class="event-form">
    <div class="form-grid">
      <label>Название<input type="text" name="name" required></label>
      <label>Город<input type="text" name="city" required></label>
    </div>
    <div class="form-grid">
      <label>Адрес<input type="text" name="address" required></label>
      <label>Вместимость<input type="number" name="capacity" min="0" value="0"></label>
    </div>
    <button type="submit">Создать</button>
  </form>
</section>

<section class="card">
  <h2>Список локаций</h2>
  <% if (locations.length) { %>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Адрес</th>
            <th>Город</th>
            <th>Вместимость</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% locations.forEach(function(loc) { %>
            <tr>
              <td><%= loc.id %></td>
              <td><%= loc.name %></td>
              <td><%= loc.address %></td>
              <td><%= loc.city %></td>
              <td><%= loc.capacity %></td>
              <td>
                <form method="post" action="/admin/locations/<%= loc.id %>/delete" style="display:inline">
                  <button type="submit" class="danger-btn" onclick="return confirm('Удалить локацию?')">Удалить</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <p>Локаций пока нет.</p>
  <% } %>
</section>

<%- include('../partials/footer') %>