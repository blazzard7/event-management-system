<%- include('../partials/header', { title, currentUser }) %>

<section class="hero">
  <h1>Админ панель</h1>
  <p>Управление пользователями и ролями.</p>
</section>

<section class="card">
  <h2>Пользователи</h2>

  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Имя</th>
          <th>Email</th>
          <th>Роль</th>
          <th>Изменить роль</th>
        </tr>
      </thead>

      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.first_name %> <%= user.last_name %></td>
            <td><%= user.email %></td>
            <td><%= user.role %></td>
            <td>
              <form action="/admin/users/<%= user.id %>/role" method="post" class="role-form">
                <select name="role">
                  <% roles.forEach(role => { %>
                    <option value="<%= role %>" <%= user.role === role ? 'selected' : '' %>>
                      <%= role %>
                    </option>
                  <% }) %>
                </select>

                <button type="submit">Сохранить</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>