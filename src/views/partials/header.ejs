<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container nav-row">
      <a class="brand" href="/">Event City</a>
      <nav class="nav-links">
        <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">Мероприятия</a>
        <% if (currentUser) { %>
          <a href="/my-events" class="<%= currentPath === '/my-events' ? 'is-active' : '' %>">Мои мероприятия</a>
          <a href="/events/new" class="<%= currentPath === '/events/new' ? 'is-active' : '' %>">Создать мероприятие</a>
          <a href="/notifications" class="<%= /^\\/notifications/.test(currentPath) ? 'is-active' : '' %>">Уведомления</a>
          <a href="/profile" class="<%= /^\\/profile/.test(currentPath) ? 'is-active' : '' %>">Профиль</a>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin/users" class="<%= currentPath === '/admin/users' ? 'is-active' : '' %>">Пользователи</a>
            <a href="/admin/categories" class="<%= currentPath === '/admin/categories' ? 'is-active' : '' %>">Категории</a>
            <a href="/admin/locations" class="<%= currentPath === '/admin/locations' ? 'is-active' : '' %>">Локации</a>
          <% } %>
          <form action="/logout" method="post" class="inline-form"><button type="submit">Выйти</button></form>
        <% } else { %>
          <a href="/login" class="<%= currentPath === '/login' ? 'is-active' : '' %>">Войти</a>
          <a href="/register" class="<%= currentPath === '/register' ? 'is-active' : '' %>">Регистрация</a>
        <% } %>
      </nav>
    </div>
  </header>
  <div class="toast-container" id="toast-container"></div>
  <script>
    window.__toasts = <%- JSON.stringify(locals.flashMessages) %>;
  </script>
  <main class="container">
