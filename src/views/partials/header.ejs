<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container nav-row">
      <a class="brand" href="/">Event City</a>
      <nav class="nav-links">
        <a href="/">Мероприятия</a>
        <% if (currentUser) { %>
          <a href="/my-events">Мои мероприятия</a>
          <a href="/events/new">Создать мероприятие</a>
          <a href="/notifications">Уведомления</a>
          <a href="/profile">Профиль</a>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin/users">Админ панель</a>
          <% } %>
          <form action="/logout" method="post" class="inline-form"><button type="submit">Выйти</button></form>
        <% } else { %>
          <a href="/login">Войти</a>
          <a href="/register">Регистрация</a>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="container">
